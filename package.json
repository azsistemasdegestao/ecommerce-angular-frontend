{
  "name": "ecommerce-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --runner-config=vitest.config.ts",
    "e2e": "playwright test",
    "fetch:openapi": "node scripts/fetch-openapi.mjs",
    "generate:api": "npm run fetch:openapi && ng-openapi-gen",
    "serve:ssr:ecommerce-frontend": "node dist/ecommerce-frontend/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.16",
    "express": "^5.1.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.16",
    "@angular/cli": "^21.2.16",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/qrcode": "^1.5.6",
    "jsdom": "^28.0.0",
    "ng-openapi-gen": "^1.0.5",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}

{
  "name": "ecommerce-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && tsc -p tsconfig.instrument.json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --runner-config=vitest.config.ts",
    "e2e": "playwright test",
    "fetch:openapi": "node scripts/fetch-openapi.mjs",
    "generate:api": "npm run fetch:openapi && ng-openapi-gen",
    "serve:ssr:ecommerce-frontend": "node --import ./dist/ecommerce-frontend/server/instrument.mjs dist/ecommerce-frontend/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.16",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/context-zone": "^2.8.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-prometheus": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation": "^0.219.0",
    "@opentelemetry/instrumentation-fetch": "^0.219.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-web": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "express": "^5.1.0",
    "pino": "^10.3.1",
    "pino-loki": "^3.0.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.16",
    "@angular/cli": "^21.2.16",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/qrcode": "^1.5.6",
    "jsdom": "^28.0.0",
    "ng-openapi-gen": "^1.0.5",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
